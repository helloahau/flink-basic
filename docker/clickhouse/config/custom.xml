<clickhouse>
    <!--
      Allow the file() table function to read from the Iceberg warehouse.
      Without this, file() is sandboxed to /var/lib/clickhouse/user_files only.
    -->
    <user_files_path>/warehouse/</user_files_path>

    <max_concurrent_queries>50</max_concurrent_queries>
    <max_connections>1024</max_connections>
</clickhouse>

